# =============================================================================
# terraform.tfvars.example - Example variable values
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
#
# IMPORTANT: Never commit terraform.tfvars to git! It contains secrets.
# The .gitignore file should already exclude it.
# =============================================================================

# -----------------------------------------------------------------------------
# GCP Project (REQUIRED)
# -----------------------------------------------------------------------------
project_id = "your-gcp-project-id"

# -----------------------------------------------------------------------------
# Region/Zone (Optional - defaults are free-tier eligible)
# -----------------------------------------------------------------------------
# Free-tier eligible regions: us-west1, us-central1, us-east1
# region = "us-central1"
# zone   = "us-central1-a"

# -----------------------------------------------------------------------------
# Service Feature Flags
# -----------------------------------------------------------------------------
# Toggle each service independently. All default to false (no services run
# unless explicitly enabled). Mix and match as needed.
#
# Typical setup (Obsidian Sync + MCPVault for Claude.ai):
#   enable_couchdb           = false  # Using Obsidian Sync instead
#   enable_headless_obsidian = true   # Sync vault to VM from Obsidian cloud
#   enable_mcpvault          = true   # Expose vault to Claude.ai via MCP
#   enable_claude_cli        = true   # Install claude CLI for cron automation
#   enable_https             = true   # Required for Claude.ai iOS MCP access
#
# Legacy setup (self-hosted CouchDB):
#   enable_couchdb           = true
#   enable_headless_obsidian = false
#   enable_mcpvault          = false

enable_couchdb           = false
enable_headless_obsidian = false
enable_mcpvault          = false
enable_claude_cli        = false

# -----------------------------------------------------------------------------
# CouchDB Credentials (only required when enable_couchdb = true)
# -----------------------------------------------------------------------------
# couchdb_user     = "admin"
# couchdb_password = "CHANGE_ME_use_a_strong_password_here_min_12_chars"

# -----------------------------------------------------------------------------
# MCPVault Configuration (only required when enable_mcpvault = true)
# -----------------------------------------------------------------------------
# Basic auth credentials that Caddy puts in front of MCPVault.
# Claude.ai connects with: https://user:password@your-subdomain.duckdns.org/sse
#
# obsidian_vault_path = "/opt/obsidian-vault"  # Where vault files live on VM
# mcpvault_user       = "admin"
# mcpvault_password   = "CHANGE_ME_use_a_strong_password_here_min_12_chars"

# -----------------------------------------------------------------------------
# Network Security
# -----------------------------------------------------------------------------
# allowed_ips controls direct port 5984 access (CouchDB only).
# With HTTPS enabled, all traffic goes through port 443 — leave this closed.
allowed_ips     = []
ssh_allowed_ips = []

# -----------------------------------------------------------------------------
# Optional: Tailscale (private SSH access without opening port 22)
# -----------------------------------------------------------------------------
# Get an auth key from: https://login.tailscale.com/admin/settings/keys
# tailscale_auth_key = "tskey-auth-xxxxxxxxxxxxxxxxxxxxx"

# -----------------------------------------------------------------------------
# HTTPS: DuckDNS + Caddy (required for Claude.ai iOS MCP access)
# -----------------------------------------------------------------------------
# Claude.ai iOS works by having Anthropic's servers connect to YOUR endpoint.
# Tailscale alone won't work — you need a public HTTPS URL.
# DuckDNS gives you a free subdomain; Caddy handles Let's Encrypt certs.
#
# Setup:
# 1. Go to https://www.duckdns.org/ and create a subdomain
# 2. Copy your DuckDNS token
# 3. Set the values below and set enable_https = true
#
# enable_https      = true
# duckdns_subdomain = "obsidian-yourname"   # WITHOUT .duckdns.org
# duckdns_token     = "your-duckdns-token-here"

# -----------------------------------------------------------------------------
# For CI/CD Reference (not used directly by Terraform)
# -----------------------------------------------------------------------------
# terraform_state_bucket = "obsidian-couchdb-tfstate-UNIQUE_SUFFIX"
